{
  "name": "@sharleysoft/openclaw-yandex-maps-places-review",
  "version": "0.1.5",
  "description": "OpenClaw tool plugin that collects recent Yandex Maps place reviews with Playwright.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openclaw-yandex-maps-places-review": "./dist/Cli/setup-playwright.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "plugin:build": "node ./node_modules/openclaw/openclaw.mjs plugins build --entry ./dist/index.js",
    "plugin:validate": "node ./node_modules/openclaw/openclaw.mjs plugins validate --entry ./dist/index.js",
    "release:metadata": "node ./scripts/check-release-metadata.mjs",
    "prepack": "npm run build && npm run plugin:build && npm run plugin:validate && npm run release:metadata",
    "test": "npm run test:unit",
    "test:unit": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 vitest run --exclude \"src/**/*.live.test.ts\"",
    "verify": "npm run build && npm run test:unit && npm run test:live && npm run plugin:build && npm run plugin:validate && npm run release:metadata",
    "test:live": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 vitest run src/Tests/Infrastructure/playwright-yandex-maps-review-collector.live.test.ts",
    "test:headed": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 HEADED=1 vitest run src/Tests/Infrastructure/playwright-yandex-maps-review-collector.live.test.ts",
    "run:tool": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 tsx scripts/run-tool.ts"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "tool",
    "yandex-maps",
    "reviews"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PavelRubis/OpenClawYandexMapsPlacesReview.git"
  },
  "homepage": "https://github.com/PavelRubis/OpenClawYandexMapsPlacesReview#readme",
  "bugs": {
    "url": "https://github.com/PavelRubis/OpenClawYandexMapsPlacesReview/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "pino": "^10.3.1",
    "playwright": "^1.55.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "cross-env": "^10.0.0",
    "openclaw": "latest",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "install": {
      "npmSpec": "@sharleysoft/openclaw-yandex-maps-places-review",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.11"
    }
  }
}
